#!/bin/sh
# 在提交前自动格式化工作流 JSON 文件，便于版本 diff 和人工阅读。
python - <<'PY'
import json
import subprocess
import sys

def get_staged_workflows():
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        capture_output=True,
        text=True,
    )
    return [
        line.strip()
        for line in result.stdout.splitlines()
        if line.startswith("user/default/workflows/") and line.endswith(".json")
    ]

def format_file(path: str) -> None:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.write("\n")

paths = get_staged_workflows()
if not paths:
    sys.exit(0)

for path in paths:
    try:
        format_file(path)
        subprocess.run(["git", "add", path], check=True)
    except Exception as e:
        print(f"格式化失败: {path} - {e}", file=sys.stderr)
        sys.exit(1)

print(f"已格式化 {len(paths)} 个工作流文件")
PY
